{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "nixpacksVersion": "latest"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyLimit": 5,
    "command": "gunicorn --bind 0.0.0.0:$PORT --workers 1 --access-logfile - --error-logfile - wsgi:app"
  }
}